#!/bin/bash
# Dev launcher: bootstraps the venv on first run, then starts the app.
set -e

BUNDLE_EXEC="${BASH_SOURCE[0]}"
PROJECT_DIR="$(cd "$(dirname "$BUNDLE_EXEC")/../../.." && pwd)"
cd "$PROJECT_DIR"

LOG="$HOME/Library/Logs/TremorAssist.log"
mkdir -p "$(dirname "$LOG")"

if [ ! -d ".venv" ]; then
  osascript -e 'display notification "Setting up for first use… this takes a moment." with title "TremorAssist"' 2>/dev/null || true
  python3 -m venv .venv >>"$LOG" 2>&1
  .venv/bin/python -m pip install --upgrade pip >>"$LOG" 2>&1
  .venv/bin/python -m pip install -r requirements.txt >>"$LOG" 2>&1
fi

exec .venv/bin/python -m tremor_assist >>"$LOG" 2>&1
